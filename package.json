{
  "name": "yieldscope",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "node scripts/check-coverage.mjs",
    "test:smoke": "tsx scripts/smoke.ts",
    "test:contracts": "forge test --root contracts",
    "test:e2e:auth": "playwright test --config=playwright.config.ts",
    "test:e2e:auth:install": "playwright install chromium",
    "demo:broll": "pnpm --dir demo-broll render",
    "demo:broll:studio": "pnpm --dir demo-broll dev"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@vitest/coverage-v8": "^4.1.10",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "viem": "^2.55.2",
    "vitest": "^4.1.10"
  }
}
