# YieldScope local / deploy env (copy to web/.env.local — never commit secrets)

# Fixture demo path (no live exchange keys). Set 1 for local UI demo with golden fixtures.
# NEVER set to 1 in production — fixtures used to invent earn rows (e.g. 2.5 MONAD)
# for users who had not connected that source.
USE_FIXTURE_DEMO=0

# Live smoke gate — adapters still unit-test without this.
SYNC_LIVE=0

# Binance (read-only API key pair — never commit real values)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_API_BASE=https://api.binance.com
# Optional server-side OAuth token (not exposed in Connect UI)
BINANCE_ACCESS_TOKEN=

# OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
# Optional pin. Unset = try www → eea → my (EEA keys fail on www with 50119).
OKX_API_BASE=
# Set to 1 for OKX demo/paper trading keys.
OKX_SIMULATED_TRADING=
OKX_ACCESS_TOKEN=

# Monad (mainnet — wallet connect + stake precompile 0x1000)
# Use mainnet RPC for YieldScope. testnet-rpc.monad.xyz is chain 10143 and will
# NOT show mainnet pending unclaimed (validators / rewards differ).
MONAD_RPC_URL=https://rpc.monad.xyz
NEXT_PUBLIC_MONAD_RPC_URL=https://rpc.monad.xyz
# ClaimRewards history via public Monad RPC (default rpc1 — wide getLogs when
# filtered by wallet topic2; full chain, no API key, no self-hosted node).
# Do NOT use rpc.monad.xyz here (~100-block getLogs cap). rpc3 is auto-fallback
# for chunked walks if the primary rejects wide ranges.
MONAD_ARCHIVE_RPC_URL=https://rpc1.monad.xyz
# Optional Etherscan API V2 key (https://etherscan.io/apikey) for Monad chainid 143.
# Adapter accepts either name (ETHERSCAN_API_KEY aliases MONAD_EXPLORER_API_KEY).
# Not required for full history (rpc1 wide getLogs covers wallet ClaimRewards).
MONAD_EXPLORER_API_KEY=
ETHERSCAN_API_KEY=
MONAD_EXPLORER_API_URL=https://api.etherscan.io/v2/api
MONAD_EXPLORER_CHAIN_ID=143
MONAD_CLAIM_LOGS_CHUNK_BLOCKS=1000
MONAD_CLAIM_HISTORY_MAX_BLOCKS=6480000
MONAD_CLAIM_LOGS_CONCURRENCY=12
# Smoke/scripts only — NEVER used by authenticated /api/sync (would fake a wallet).
MONAD_DEMO_ADDRESS=
# EarningsCheckpoint — leave empty / zero until a mainnet deploy exists (fail closed).
# Historical Spark deploys used Monad testnet (chain 10143); wallet default is mainnet 143.
NEXT_PUBLIC_CHECKPOINT_ADDRESS=

# Terra Classic / LUNC (public LCD/FCD — no keys)
# FCD indexes multi-year account txs (autostake / withdraw_rewards). Public LCDs
# typically prune ~100 days of blocks — LCD is fallback + pending rewards only.
LUNC_FCD_URL=https://terra-classic-fcd.publicnode.com
LUNC_FCD_FALLBACKS=https://fcd.terra-classic.hexxagon.io
LUNC_LCD_URL=https://terra-classic-lcd.publicnode.com
LUNC_LCD_FALLBACKS=https://api-lunc-lcd.binodes.com
# Smoke/scripts only — NEVER used by authenticated /api/sync.
LUNC_DEMO_ADDRESS=

# WalletConnect (RainbowKit modal) — get a free id at https://cloud.walletconnect.com
# Baked into the Next.js image at build time (not a runtime k8s secret).
# Deploy: NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=<id> ./deploy/scripts/k8s-yieldscope-web-build.sh
# If unset, builds fall back to RainbowKit's shared demo id (works, but rate-limited).
# Avoid `NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=` (empty string) in .env.local.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Foundry deploy (contracts/)
DEPLOYER_PK=
CHECKPOINT_OWNER=

# Supabase Auth + ledger — dedicated YieldScope instance (NOT majico staging)
# Prod URL: https://supabase.yieldscope.d3bu7.com
# Keys: kubectl -n supabase-yieldscope get secret yieldscope-supabase-secrets
NEXT_PUBLIC_SUPABASE_URL=https://supabase.yieldscope.d3bu7.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional dedicated key for encrypting stored CEX credentials at rest.
# Falls back to SUPABASE_SERVICE_ROLE_KEY when unset.
CREDENTIALS_ENCRYPTION_KEY=
# Kong Studio basic-auth (browser login at Studio URL) — NOT the anon/service JWT keys.
# From k8s secret yieldscope-supabase-secrets (DASHBOARD_USERNAME / DASHBOARD_PASSWORD).
SUPABASE_STUDIO_URL=https://supabase.yieldscope.d3bu7.com
SUPABASE_STUDIO_USERNAME=
SUPABASE_STUDIO_PASSWORD=
# Auth emails are automated via GoTrue GOTRUE_SMTP_* → self-hosted yieldscope-mail
# (noreply@yieldscope.d3bu7.com). See deploy/k8s/yieldscope-mail/README.md.
# E2E inbox: e2e@yieldscope.d3bu7.com (plus-addressing). Run: pnpm test:e2e:auth
# Confirm email required (GOTRUE_MAILER_AUTOCONFIRM=false). Site URL / redirect allow-list
# are set in deploy/k8s/supabase-yieldscope/configmap.yaml:
#   Site URL: https://yieldscope.d3bu7.com (app — NOT the supabase.* API host)
#   Allow: https://yieldscope.d3bu7.com/** (+ explicit /auth/callback, /auth/reset-password)
#   Mailer paths: GOTRUE_MAILER_URLPATHS_*=/auth/v1/verify (bare /verify hits Studio)
# Auth email branding is deploy-managed (not Studio): HTML under
#   deploy/k8s/supabase-yieldscope/email-templates/ + GOTRUE_MAILER_TEMPLATES_* /
#   GOTRUE_MAILER_SUBJECTS_* in that configmap, served by auth-mail-templates.
# Password reset: redirectTo → /auth/reset-password (path only; handles ?code= / #access_token= / token_hash)
# After reset, app signs out and sends the user to /login?password_updated=1 so the
# new password is verified explicitly via signInWithPassword.
