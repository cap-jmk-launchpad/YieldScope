# YieldScope local / deploy env (copy to web/.env.local — never commit secrets)

# Fixture demo path (no live exchange keys). Set 1 for local UI demo with golden fixtures.
USE_FIXTURE_DEMO=0

# Live smoke gate — adapters still unit-test without this.
SYNC_LIVE=0

# Binance (read-only API key pair — never commit real values)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_API_BASE=https://api.binance.com
# Optional server-side OAuth token (not exposed in Connect UI)
BINANCE_ACCESS_TOKEN=

# OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_API_BASE=https://www.okx.com
OKX_ACCESS_TOKEN=

# Monad
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_DEMO_ADDRESS=
NEXT_PUBLIC_CHECKPOINT_ADDRESS=

# Terra Classic / LUNC (public LCD — no keys)
LUNC_LCD_URL=https://terra-classic-lcd.publicnode.com
LUNC_DEMO_ADDRESS=

# WalletConnect (RainbowKit modal) — get a free id at https://cloud.walletconnect.com
# Required in production. Local dev works when unset; avoid `NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=` (empty string).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Foundry deploy (contracts/)
DEPLOYER_PK=
CHECKPOINT_OWNER=

# Supabase Auth + ledger — dedicated YieldScope instance (NOT majico staging)
# Prod URL: https://supabase.yieldscope.d3bu7.com
# Keys: kubectl -n supabase-yieldscope get secret yieldscope-supabase-secrets
NEXT_PUBLIC_SUPABASE_URL=https://supabase.yieldscope.d3bu7.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional dedicated key for encrypting stored CEX credentials at rest.
# Falls back to SUPABASE_SERVICE_ROLE_KEY when unset.
CREDENTIALS_ENCRYPTION_KEY=
# Kong Studio basic-auth (browser login at Studio URL) — NOT the anon/service JWT keys.
# From k8s secret yieldscope-supabase-secrets (DASHBOARD_USERNAME / DASHBOARD_PASSWORD).
SUPABASE_STUDIO_URL=https://supabase.yieldscope.d3bu7.com
SUPABASE_STUDIO_USERNAME=
SUPABASE_STUDIO_PASSWORD=
# Auth emails are automated via GoTrue GOTRUE_SMTP_* → self-hosted yieldscope-mail
# (noreply@yieldscope.d3bu7.com). See deploy/k8s/yieldscope-mail/README.md.
# E2E inbox: e2e@yieldscope.d3bu7.com (plus-addressing). Run: pnpm test:e2e:auth
# Confirm email required (GOTRUE_MAILER_AUTOCONFIRM=false). Site URL / redirect allow-list
# are set in deploy/k8s/supabase-yieldscope/configmap.yaml:
#   Site URL: https://yieldscope.d3bu7.com (app — NOT the supabase.* API host)
#   Allow: https://yieldscope.d3bu7.com/** (+ explicit /auth/callback, /auth/reset-password)
#   Mailer paths: GOTRUE_MAILER_URLPATHS_*=/auth/v1/verify (bare /verify hits Studio)
# Auth email branding is deploy-managed (not Studio): HTML under
#   deploy/k8s/supabase-yieldscope/email-templates/ + GOTRUE_MAILER_TEMPLATES_* /
#   GOTRUE_MAILER_SUBJECTS_* in that configmap, served by auth-mail-templates.
# Password reset: redirectTo → /auth/reset-password (path only; handles ?code= / #access_token= / token_hash)
# After reset, app signs out and sends the user to /login?password_updated=1 so the
# new password is verified explicitly via signInWithPassword.
