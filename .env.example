# YieldScope local / deploy env (copy to web/.env.local — never commit secrets)

# Fixture demo path (no live exchange keys). Set 1 for local UI demo with golden fixtures.
USE_FIXTURE_DEMO=0

# Live smoke gate — adapters still unit-test without this.
SYNC_LIVE=0

# Binance (read-only API key pair — never commit real values)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_API_BASE=https://api.binance.com
# Optional server-side OAuth token (not exposed in Connect UI)
BINANCE_ACCESS_TOKEN=

# OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_API_BASE=https://www.okx.com
OKX_ACCESS_TOKEN=

# Monad
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_DEMO_ADDRESS=
NEXT_PUBLIC_CHECKPOINT_ADDRESS=

# Terra Classic / LUNC (public LCD — no keys)
LUNC_LCD_URL=https://terra-classic-lcd.publicnode.com
LUNC_DEMO_ADDRESS=

# WalletConnect (RainbowKit modal) — get a free id at https://cloud.walletconnect.com
# Required in production. Local dev works when unset; avoid `NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=` (empty string).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Foundry deploy (contracts/)
DEPLOYER_PK=
CHECKPOINT_OWNER=

# Supabase Auth + ledger (blackpearl / engine)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# In Supabase Dashboard → Authentication → Providers → Email: enable "Confirm email".
# Registration stays inactive until the user clicks the link (bot protection without captcha).
# Supabase Dashboard → Auth → URL Configuration:
# Site URL (prod): https://yieldscope.d3bu7.com
# Redirect URLs (allow PKCE callback + post-auth destinations):
#   http://localhost:3000/auth/callback
#   http://localhost:3000/auth/reset-password
#   https://yieldscope.d3bu7.com/auth/callback
#   https://yieldscope.d3bu7.com/auth/reset-password
# Password reset emails use redirectTo → /auth/callback?next=/auth/reset-password
# (same callback as signup confirmation; recovery codes exchange there too).
# Bot protection: email confirmation only (no captcha / Turnstile).
